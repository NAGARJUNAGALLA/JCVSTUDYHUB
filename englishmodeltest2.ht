                            <div class="quiz-score-display" style="display: none;"></div>
                        </div>
                        <div class="quiz-q-container" style="display: none; text-align: left;" data-answer="C">
                            
                            
                            <div class="quiz-question"><b>Q26.</b> . She _____ unconscious since four' o clock. Choose the correct verb form.</div>
                            <div class="quiz-options">
                                <label class="quiz-opt" style="border-color: rgb(224, 224, 224);"><input type="radio" name="quiz-block-1782270776285266" value="A"><div class="quiz-opt-letter">A</div><div>were</div></label>
                                <label class="quiz-opt" style="border-color: rgb(224, 224, 224);"><input type="radio" name="quiz-block-1782270776285266" value="B"><div class="quiz-opt-letter">B</div><div>was</div></label>
                                <label class="quiz-opt" style="border-color: rgb(224, 224, 224);"><input type="radio" name="quiz-block-1782270776285266" value="C"><div class="quiz-opt-letter">C</div><div>has been</div></label>
                                <label class="quiz-opt" style="border-color: rgb(224, 224, 224);"><input type="radio" name="quiz-block-1782270776285266" value="D"><div class="quiz-opt-letter">D</div><div>will be</div></label>
                            </div>
                            <div class="quiz-explanation" style="display: none;">
                                <b>Explanation:</b><br>No explanation provided.
                            </div>
                            <div class="quiz-score-display" style="display: none;"></div>
                        </div>
                        <div class="quiz-q-container" style="display: none; text-align: left;" data-answer="A">
                            
                            
                            <div class="quiz-question"><b>Q27.</b> . Choose the correct matching. <br>1) Flakes of     a) stones<br>2) A portion of     b) snow<br>3) A huge heap of     c) fried fish<br>4) A pot of     d) gold)</div>
                            <div class="quiz-options">
                                <label class="quiz-opt" style="border-color: rgb(224, 224, 224);"><input type="radio" name="quiz-block-1782270776285333" value="A"><div class="quiz-opt-letter">A</div><div>1-b, 2-c,3 -a,4 -d</div></label>
                                <label class="quiz-opt" style="border-color: rgb(224, 224, 224);"><input type="radio" name="quiz-block-1782270776285333" value="B"><div class="quiz-opt-letter">B</div><div>1-b, 2-d, 3-a, 4-c</div></label>
                                <label class="quiz-opt" style="border-color: rgb(224, 224, 224);"><input type="radio" name="quiz-block-1782270776285333" value="C"><div class="quiz-opt-letter">C</div><div>1-c, 2-b, 3-a, 4-d</div></label>
                                <label class="quiz-opt" style="border-color: rgb(224, 224, 224);"><input type="radio" name="quiz-block-1782270776285333" value="D"><div class="quiz-opt-letter">D</div><div>1-c, 2-a, 3-b, 4-d</div></label>
                            </div>
                            <div class="quiz-explanation" style="display: none;">
                                <b>Explanation:</b><br>No explanation provided.
                            </div>
                            <div class="quiz-score-display" style="display: none;"></div>
                        </div>
                        <div class="quiz-q-container" style="display: none; text-align: left;" data-answer="B">
                            
                            
                            <div class="quiz-question"><b>Q28.</b> . _____ his negligence the company suffered a heavy loss. Fill in the blank with appropriate phrase preposition.</div>
                            <div class="quiz-options">
                                <label class="quiz-opt" style="border-color: rgb(224, 224, 224);"><input type="radio" name="quiz-block-1782270776285718" value="A"><div class="quiz-opt-letter">A</div><div>In case of</div></label>
                                <label class="quiz-opt" style="border-color: rgb(224, 224, 224);"><input type="radio" name="quiz-block-1782270776285718" value="B"><div class="quiz-opt-letter">B</div><div>On account of</div></label>
                                <label class="quiz-opt" style="border-color: rgb(224, 224, 224);"><input type="radio" name="quiz-block-1782270776285718" value="C"><div class="quiz-opt-letter">C</div><div>For the sake of</div></label>
                                <label class="quiz-opt" style="border-color: rgb(224, 224, 224);"><input type="radio" name="quiz-block-1782270776285718" value="D"><div class="quiz-opt-letter">D</div><div>By means of</div></label>
                            </div>
                            <div class="quiz-explanation" style="display: none;">
                                <b>Explanation:</b><br>No explanation provided.
                            </div>
                            <div class="quiz-score-display" style="display: none;"></div>
                        </div>
                        <div class="quiz-q-container" style="display: none; text-align: left;" data-answer="B">
                            
                            
                            <div class="quiz-question"><b>Q29.</b> . What is the fourth leading cause of death worldwide?</div>
                            <div class="quiz-options">
                                <label class="quiz-opt" style="border-color: rgb(224, 224, 224);"><input type="radio" name="quiz-block-1782270776285448" value="A"><div class="quiz-opt-letter">A</div><div>walking</div></label>
                                <label class="quiz-opt" style="border-color: rgb(224, 224, 224);"><input type="radio" name="quiz-block-1782270776285448" value="B"><div class="quiz-opt-letter">B</div><div>physical inactivity</div></label>
                                <label class="quiz-opt" style="border-color: rgb(224, 224, 224);"><input type="radio" name="quiz-block-1782270776285448" value="C"><div class="quiz-opt-letter">C</div><div>running</div></label>
                                <label class="quiz-opt" style="border-color: rgb(224, 224, 224);"><input type="radio" name="quiz-block-1782270776285448" value="D"><div class="quiz-opt-letter">D</div><div>playing</div></label>
                            </div>
                            <div class="quiz-explanation" style="display: none;">
                                <b>Explanation:</b><br>No explanation provided.
                            </div>
                            <div class="quiz-score-display" style="display: none;"></div>
                        </div>
                        <div class="quiz-q-container" style="display: none; text-align: justify;" data-answer="B">
                            
                            
                            <div class="quiz-question"><b>Q30.</b> <b>Read the following passage.</b><br><br>Physical inactivity is the fourth leading cause of death worldwide. It's also associated with chronic illness and disability. Regular physical activity helps to prevent and manage many chronic diseases. Popular ways to be physically active include walking, running, cycling, and playing sports.<br><br>What is the fourth leading cause of death worldwide?</div>
                            <div class="quiz-options">
                                <label class="quiz-opt" style="border-color: rgb(224, 224, 224);"><input type="radio" name="quiz-block-1782271208743316" value="A"><div class="quiz-opt-letter">A</div><div>walking</div></label>
                                <label class="quiz-opt" style="border-color: rgb(224, 224, 224);"><input type="radio" name="quiz-block-1782271208743316" value="B"><div class="quiz-opt-letter">B</div><div>physical inactivity</div></label>
                                <label class="quiz-opt" style="border-color: rgb(224, 224, 224);"><input type="radio" name="quiz-block-1782271208743316" value="C"><div class="quiz-opt-letter">C</div><div>running</div></label>
                                <label class="quiz-opt" style="border-color: rgb(224, 224, 224);"><input type="radio" name="quiz-block-1782271208743316" value="D"><div class="quiz-opt-letter">D</div><div>playing</div></label>
                            </div>
                            <div class="quiz-explanation" style="display: none;">
                                <b>Explanation:</b><br>No explanation provided.
                            </div>
                            <div class="quiz-score-display" style="display: none;"></div>
                        </div>
                            </div>
                            <div class="quiz-controls">
                                <button class="btn-prev" disabled="" style="display: inline-block;">Previous</button>
                                <button class="btn-submit-exam" onclick="QuizEngine.submit(this)" style="display: inline-block;">Submit</button>
                                <button class="btn-next" style="display: inline-block;">Next</button>
                            </div>
                        </div>
                        <div class="quiz-sidebar">
                            <button class="quiz-palette-close">×</button>
                            <div class="quiz-legend">
                                <div class="legend-item"><div class="legend-box" style="background:#4caf50;"></div> Answered (<span class="cnt-ans">0</span>)</div>
                                <div class="legend-item"><div class="legend-box" style="background:#f44336;"></div> Not Answered (<span class="cnt-not-ans">30</span>)</div>
                                <div class="legend-item"><div class="legend-box" style="background:#ffffff; border:1px solid #ccc;"></div> Not Visited (<span class="cnt-not-vis">0</span>)</div>
                            </div>
                            <div class="palette-grid-wrapper">
                                <div class="palette-grid">
                                    <button class="palette-btn not-answered active">1</button><button class="palette-btn not-answered">2</button><button class="palette-btn not-answered">3</button><button class="palette-btn not-answered">4</button><button class="palette-btn not-answered">5</button><button class="palette-btn not-answered">6</button><button class="palette-btn not-answered">7</button><button class="palette-btn not-answered">8</button><button class="palette-btn not-answered">9</button><button class="palette-btn not-answered">10</button><button class="palette-btn not-answered">11</button><button class="palette-btn not-answered">12</button><button class="palette-btn not-answered">13</button><button class="palette-btn not-answered">14</button><button class="palette-btn not-answered">15</button><button class="palette-btn not-answered">16</button><button class="palette-btn not-answered">17</button><button class="palette-btn not-answered">18</button><button class="palette-btn not-answered">19</button><button class="palette-btn not-answered">20</button><button class="palette-btn not-answered">21</button><button class="palette-btn not-answered">22</button><button class="palette-btn not-answered">23</button><button class="palette-btn not-answered">24</button><button class="palette-btn not-answered">25</button><button class="palette-btn not-answered">26</button><button class="palette-btn not-answered">27</button><button class="palette-btn not-answered">28</button><button class="palette-btn not-answered">29</button><button class="palette-btn not-answered">30</button>
                                </div>
                            </div>
                        </div>
                    </div></div>
        
    </div>

    <script>
                    const QuizEngine = {
                        init: function() {
                            document.querySelectorAll('.quiz-widget').forEach((widget, wIdx) => {
                                if (widget.dataset.initialized) return;
                                widget.dataset.initialized = 'true';
                                
                                const questions = widget.querySelectorAll('.quiz-q-container');
                                const paletteBtns = widget.querySelectorAll('.palette-btn');
                                const prevBtn = widget.querySelector('.btn-prev');
                                const nextBtn = widget.querySelector('.btn-next');
                                const timerEl = widget.querySelector('.quiz-timer');
                                const startOverlay = widget.querySelector('.quiz-start-overlay');
                                const startBtn = widget.querySelector('.btn-start-quiz');
                                const toggleBtn = widget.querySelector('.quiz-palette-toggle');
                                const closeSidebarBtn = widget.querySelector('.quiz-palette-close');
                                const sidebar = widget.querySelector('.quiz-sidebar');
                                const qWrapper = widget.querySelector('.quiz-q-wrapper');
                                
                                let currentIdx = 0;
                                let statuses = Array(questions.length).fill('not-visited');
                                let totalSeconds = questions.length * 60;
                                let isSubmitted = false;

                                function updateUI() {
                                    questions.forEach((q, qIdx) => { q.style.display = qIdx === currentIdx ? 'block' : 'none'; });
                                    if(prevBtn) prevBtn.disabled = currentIdx === 0;
                                    if(nextBtn) nextBtn.disabled = currentIdx === questions.length - 1;
                                    
                                    paletteBtns.forEach((btn, qIdx) => {
                                        btn.className = 'palette-btn ' + statuses[qIdx];
                                        if(qIdx === currentIdx) btn.classList.add('active');
                                    });
                                    
                                    const cntAns = widget.querySelector('.cnt-ans');
                                    const cntNotAns = widget.querySelector('.cnt-not-ans');
                                    const cntNotVis = widget.querySelector('.cnt-not-vis');
                                    
                                    if(cntAns) cntAns.innerText = statuses.filter(s=>s==='answered').length;
                                    if(cntNotAns) cntNotAns.innerText = statuses.filter(s=>s==='not-answered').length;
                                    if(cntNotVis) cntNotVis.innerText = statuses.filter(s=>s==='not-visited').length;
                                    
                                    if(qWrapper) qWrapper.scrollTop = 0;
                                }

                                function formatTime(sec) {
                                    let m = Math.floor(sec / 60).toString().padStart(2, '0');
                                    let s = (sec % 60).toString().padStart(2, '0');
                                    return m + ':' + s;
                                }

                                function startTimer() {
                                    timerEl.innerHTML = "⏳ " + formatTime(totalSeconds);
                                    if(widget.dataset.timerId) clearInterval(parseInt(widget.dataset.timerId));
                                    
                                    let tid = setInterval(() => {
                                        if (widget.dataset.submitted === 'true') { 
                                            clearInterval(tid); 
                                            return; 
                                        }
                                        totalSeconds--;
                                        timerEl.innerHTML = "⏳ " + formatTime(totalSeconds);
                                        if (totalSeconds <= 0) {
                                            clearInterval(tid);
                                            alert("⏳ Time is up! Auto-submitting the exam.");
                                            QuizEngine.submit(widget, true);
                                        }
                                    }, 1000);
                                    widget.dataset.timerId = tid;
                                }

                                if (startBtn) {
                                    startBtn.addEventListener('click', () => {
                                        startOverlay.style.display = 'none';
                                        statuses[0] = 'not-answered';
                                        updateUI();
                                        startTimer();
                                    });
                                }

                                if (toggleBtn) toggleBtn.addEventListener('click', () => { sidebar.classList.add('open'); });
                                if (closeSidebarBtn) closeSidebarBtn.addEventListener('click', () => { sidebar.classList.remove('open'); });

                                questions.forEach((q, qIdx) => {
                                    q.querySelectorAll('input[type="radio"]').forEach(radio => {
                                        radio.addEventListener('change', () => {
                                            statuses[qIdx] = 'answered';
                                            updateUI();
                                        });
                                    });
                                });
                                
                                paletteBtns.forEach((btn, qIdx) => {
                                    btn.addEventListener('click', () => {
                                        if(statuses[qIdx] === 'not-visited') statuses[qIdx] = 'not-answered';
                                        currentIdx = qIdx;
                                        updateUI();
                                        sidebar.classList.remove('open'); 
                                    });
                                });
                                
                                if(prevBtn) prevBtn.addEventListener('click', () => {
                                    if(currentIdx > 0) {
                                        currentIdx--;
                                        if(statuses[currentIdx] === 'not-visited') statuses[currentIdx] = 'not-answered';
                                        updateUI();
                                    }
                                });
                                if(nextBtn) nextBtn.addEventListener('click', () => {
                                    if(currentIdx < questions.length - 1) {
                                        currentIdx++;
                                        if(statuses[currentIdx] === 'not-visited') statuses[currentIdx] = 'not-answered';
                                        updateUI();
                                    }
                                });
                            });
                        },
                        submit: function(widgetOrBtn, isAuto = false) {
                            const widget = widgetOrBtn.closest ? widgetOrBtn.closest('.quiz-widget') : widgetOrBtn;
                            if (widget.dataset.submitted === 'true') return;

                            const questions = widget.querySelectorAll('.quiz-q-container');
                            let score = 0;
                            let allAttempted = true;

                            questions.forEach(q => {
                                let answered = false;
                                q.querySelectorAll('input[type="radio"]').forEach(r => { if(r.checked) answered = true; });
                                if(!answered) allAttempted = false;
                            });

                            if(!isAuto && !allAttempted) {
                                if(!confirm("You have unattempted questions! Are you sure you want to submit?")) return;
                            }

                            widget.dataset.submitted = 'true';
                            if(widget.dataset.timerId) clearInterval(parseInt(widget.dataset.timerId));

                            questions.forEach(q => {
                                const ans = q.getAttribute('data-answer');
                                const checked = q.querySelector('input[type="radio"]:checked');
                                const opts = q.querySelectorAll('.quiz-opt');

                                opts.forEach(opt => {
                                    const radio = opt.querySelector('input[type="radio"]');
                                    if(radio.value === ans) {
                                        opt.style.backgroundColor = '#c8e6c9'; 
                                        opt.style.borderColor = '#4caf50';
                                    } else if (radio.checked && radio.value !== ans) {
                                        opt.style.backgroundColor = '#ffcdd2'; 
                                        opt.style.borderColor = '#f44336';
                                    }
                                    radio.disabled = true; 
                                });

                                if(checked && checked.value === ans) score++;
                                const exp = q.querySelector('.quiz-explanation');
                                if(exp) exp.style.display = 'block';
                                
                                const display = q.querySelector('.quiz-score-display');
                                if(display) {
                                    display.innerHTML = '🏁 Final Score: ' + score + ' / ' + questions.length;
                                    display.style.display = 'block';
                                }
                            });

                            const submitBtn = widget.querySelector('.btn-submit-exam');
                            if(submitBtn) submitBtn.style.display = 'none';
                        }
                    };
                    window.addEventListener('DOMContentLoaded', () => { QuizEngine.init(true); });
                </script>
</body>
</html>
